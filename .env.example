# === Server ===
PORT=3000
NODE_ENV=development

# === Database ===
MONGODB_URI=mongodb://localhost:27017/multi_vendor_marketplace

# === Session ===
SESSION_SECRET=your-session-secret-change-in-production

# === Razorpay (Payment Gateway) ===
# Get keys from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# === Email (SMTP) ===
# Leave empty to use Ethereal test account
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Marketplace <no-reply@marketplace.com>

# === AI (Optional) ===
# Supports OpenRouter or OpenAI for enhanced search/recommendations
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# === External Products API ===
# DummyJSON is free, no key needed. Products load from https://dummyjson.com
EXTERNAL_API_ENABLED=true
