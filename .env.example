# MongoDB Connection String
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/marketplace

# Session Secret (change this to a long random string)
SESSION_SECRET=your-super-secret-session-key-change-me

# Server Port
PORT=3000

# Razorpay Payment Gateway Credentials
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Email Configuration (Optional)
# If not set, emails will use Ethereal test accounts
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Marketplace <no-reply@yourdomain.com>

# AI Chatbot Configuration (Optional)
# Choose ONE of the following:

# Option 1: OpenRouter (RECOMMENDED - has free models!)
# Get from: https://openrouter.ai/keys
# Uses free model by default, or set AI_MODEL for specific model
OPENROUTER_API_KEY=sk-or-your-key-here
# AI_MODEL=openrouter/free                    # Free model (default)
# AI_MODEL=openai/gpt-4o-mini                 # Cheap paid model
# AI_MODEL=meta-llama/llama-3.3-70b-instruct  # Powerful open-source

# Option 2: Direct OpenAI
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# If neither is set, chatbot uses smart rule-based responses (still works great!)
