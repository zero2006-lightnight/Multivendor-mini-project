<%- include('partials/header') %>

<div class="text-center py-5">
    <h1 class="display-1 text-muted"><%= typeof statusCode !== 'undefined' ? statusCode : 500 %></h1>
    <h2><%= typeof message !== 'undefined' ? message : 'Something went wrong' %></h2>
    <p class="text-muted mt-3"><%= typeof description !== 'undefined' ? description : 'The page you are looking for does not exist or an error occurred.' %></p>
    <a href="/" class="btn btn-primary mt-3">Go to Homepage</a>
</div>

<%- include('partials/footer') %>
