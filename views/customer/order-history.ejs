
<%- include('../partials/header') %>

<h2>My Orders</h2>

<% if (orders.length > 0) { %>
    <% orders.forEach(order => { %>
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>
                    Order #<%= order._id %>
                    &mdash; <%= new Date(order.createdAt).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                </span>
                <span class="badge 
                    <% if (order.status === 'Delivered') { %>bg-success
                    <% } else if (order.status === 'Cancelled') { %>bg-danger
                    <% } else if (order.status === 'Shipped') { %>bg-info
                    <% } else if (order.status === 'Processing') { %>bg-primary
                    <% } else if (order.status === 'Paid') { %>bg-warning text-dark
                    <% } else { %>bg-secondary<% } %>">
                    <%= order.status %>
                </span>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="mb-1"><strong>Total:</strong> ₹<%= order.totalAmount.toFixed(2) %></p>
                        <% if (order.discount > 0) { %>
                            <p class="text-success small mb-1"><%= order.discount %>% coupon discount applied<% if (order.couponCode) { %> (<%= order.couponCode %>)<% } %></p>
                        <% } %>
                        <% if (order.paymentId) { %>
                            <p class="text-muted small mb-1">Payment ID: <%= order.paymentId %></p>
                        <% } %>
                    </div>
                    <a href="/invoice/<%= order._id %>" class="btn btn-outline-primary btn-sm">🧾 Invoice</a>
                </div>
                <h6 class="mt-2">Products:</h6>
                <ul class="list-group list-group-flush mb-2">
                    <% order.products.forEach(item => { %>
                        <li class="list-group-item d-flex justify-content-between">
                            <span><%= item.product ? item.product.name : 'Product' %> (x<%= item.quantity %>)</span>
                            <span>₹<%= (item.price * item.quantity).toFixed(2) %></span>
                        </li>
                    <% }) %>
                </ul>
            </div>
        </div>
    <% }) %>
<% } else { %>
    <div class="text-center py-5">
        <h4 class="text-muted">No orders yet</h4>
        <p>Start shopping to see your orders here!</p>
        <a href="/" class="btn btn-primary">Browse Products</a>
    </div>
<% } %>

<%- include('../partials/footer') %>


