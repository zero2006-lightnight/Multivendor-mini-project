<%- include('../partials/header') %>

<% if(success_msg.length > 0) { %>
    <div class="alert alert-success"><%= success_msg %></div>
<% } %>
<% if(error_msg.length > 0) { %>
    <div class="alert alert-danger"><%= error_msg %></div>
<% } %>

<div class="product-detail-page">
    <div style="margin-bottom:1.5rem;">
        <button onclick="history.back()" class="btn btn-outline-secondary" style="padding:0.45rem 0.9rem;font-size:0.85rem;">&larr; Back</button>
    </div>
    <div class="row">
        <div class="col-lg-6">
            <div class="product-detail-img">
                <% const img = product.image || '/images/placeholder.png'; %>
                <img src="<%= img %>" alt="<%= product.name %>">
            </div>
        </div>
        <div class="col-lg-6">
            <div class="product-detail-info">
                <h1><%= product.name %></h1>

                <div class="star-rating" style="margin-bottom: 0.75rem;">
                    <% for (let i = 1; i <= 5; i++) { %><span<%= i <= Math.round(averageRating) ? '' : ' class="empty"' %>><%= i <= Math.round(averageRating) ? '&#9733;' : '&#9734;' %></span><% } %>
                    <span style="font-family: 'DM Sans', sans-serif; font-size: 0.82rem; color: var(--text-secondary); margin-left: 0.5rem;">
                        <%= averageRating %> / 5 (<%= reviewCount %> reviews)
                    </span>
                </div>

                <div class="product-detail-meta">
                    <div>Sold by <strong><%= product.vendor.shopName %></strong></div>
                    <div class="stock-indicator <%= product.stock > 0 ? 'in-stock' : 'out-of-stock' %>">
                        <%= product.stock > 0 ? product.stock + ' in stock' : 'Out of stock' %>
                    </div>
                </div>

                <div class="product-detail-price">&#8377;<%= product.price.toFixed(2) %></div>

                <div class="product-detail-actions">
                    <div style="display: flex; gap: 0.75rem; align-items: center;">
                        <input type="number" id="pd-qty" value="1" min="1" max="<%= product.stock %>"
                               class="form-control" style="width: 80px; text-align: center;">
                        <button type="button" class="btn btn-primary" onclick="addToCart('<%= product._id %>', this)">Add to Cart</button>
                    </div>
                    <% if (user) { %>
                        <form action="/wishlist/<%= product._id %>" method="POST">
                            <button type="submit" class="btn btn-outline-secondary">Wishlist</button>
                        </form>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- AI: Similar Products -->
    <% if (typeof similarProducts !== 'undefined' && similarProducts.length > 0) { %>
    <div class="external-section" style="margin-top: 3rem;">
        <div class="external-section-header">
            <h3><span class="accent-dot"></span> Similar Products <small style="font-size: 0.68rem; font-weight: 400; text-transform: none; letter-spacing: 0; color: var(--text-muted);">AI Recommended</small></h3>
        </div>
        <div class="row">
            <% similarProducts.forEach(p => { %>
            <div class="col-md-3 mb-3">
                <div class="card product-card h-100">
                    <% const simImg = p.image || '/images/placeholder.png'; %>
                    <img src="<%= simImg %>" class="card-img-top" alt="<%= p.name %>">
                    <div class="card-body">
                        <div class="card-title"><%= p.name %></div>
                        <div class="price-tag" style="margin-bottom: 0.75rem;">&#8377;<%= p.price.toFixed(2) %></div>
                        <a href="/product/<%= p._id %>" class="btn btn-outline-primary" style="width: 100%;">View</a>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
    <% } %>

    <!-- AI: Customers Also Bought -->
    <% if (typeof alsoBoughtProducts !== 'undefined' && alsoBoughtProducts.length > 0) { %>
    <div class="external-section">
        <div class="external-section-header">
            <h3><span class="accent-dot"></span> Customers Also Bought <small style="font-size: 0.68rem; font-weight: 400; text-transform: none; letter-spacing: 0; color: var(--text-muted);">AI Recommended</small></h3>
        </div>
        <div class="row">
            <% alsoBoughtProducts.forEach(p => { %>
            <div class="col-md-3 mb-3">
                <div class="card product-card h-100">
                    <% const abImg = p.image || '/images/placeholder.png'; %>
                    <img src="<%= abImg %>" class="card-img-top" alt="<%= p.name %>">
                    <div class="card-body">
                        <div class="card-title"><%= p.name %></div>
                        <div class="price-tag" style="margin-bottom: 0.75rem;">&#8377;<%= p.price.toFixed(2) %></div>
                        <a href="/product/<%= p._id %>" class="btn btn-outline-primary" style="width: 100%;">View</a>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
    <% } %>

    <!-- Reviews Section -->
    <div style="margin-top: 3rem;">
        <h3 style="font-size: 1.4rem; margin-bottom: 1.5rem;">Reviews</h3>

        <form action="/product/<%= product._id %>" method="GET" class="mb-4">
            <select name="sort" class="form-control" onchange="this.form.submit()" style="width: auto; display: inline-block;">
                <option value="latest" <%= currentSort === 'latest' ? 'selected' : '' %>>Latest First</option>
                <option value="oldest" <%= currentSort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
                <option value="highest" <%= currentSort === 'highest' ? 'selected' : '' %>>Highest Rating</option>
                <option value="lowest" <%= currentSort === 'lowest' ? 'selected' : '' %>>Lowest Rating</option>
            </select>
        </form>

        <% if (reviews.length > 0) { %>
            <% reviews.forEach(review => { %>
                <div class="card mb-3">
                    <div class="card-body">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
                            <div>
                                <strong style="font-family: 'DM Sans', sans-serif; font-size: 0.9rem;"><%= review.user.username %></strong>
                                <span class="badge bg-success" style="margin-left: 0.5rem;">Verified Purchase</span>
                            </div>
                            <div class="star-rating" style="font-size: 0.85rem;">
                                <% for (let i = 1; i <= 5; i++) { %><span<%= i <= review.rating ? '' : ' class="empty"' %>><%= i <= review.rating ? '&#9733;' : '&#9734;' %></span><% } %>
                            </div>
                        </div>
                        <p style="font-size: 0.9rem; line-height: 1.6; color: var(--text-secondary);"><%= review.comment %></p>
                        <div style="display: flex; gap: 0.5rem; margin-top: 0.75rem;">
                            <%
                            const liked = user ? (review.helpfulUsers || []).some(id => id.toString() === user._id.toString()) : false;
                            %>
                            <form action="/review/helpful/<%= review._id %>" method="POST" style="display:inline;">
                                <button type="submit" class="btn <%= liked ? 'btn-primary' : 'btn-outline-secondary' %> btn-sm">
                                    Helpful (<%= review.helpfulUsers.length %>)
                                </button>
                            </form>
                            <a href="/review/edit/<%= review._id %>" class="btn btn-outline-secondary btn-sm">Edit</a>
                            <form action="/review/delete/<%= review._id %>" method="POST" style="display:inline;">
                                <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Delete this review?')">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="empty-state" style="padding: 3rem 0;">
                <p>No reviews yet. Be the first to share your thoughts.</p>
            </div>
        <% } %>

        <% if (user) { %>
        <div class="form-section" style="margin-top: 2rem;">
            <div class="form-section-title">Write a Review</div>
            <form action="/review/<%= product._id %>" method="POST">
                <div class="mb-3">
                    <label class="form-label">Rating</label>
                    <select name="rating" class="form-control" style="width: auto;">
                        <option value="5">5 Stars</option>
                        <option value="4">4 Stars</option>
                        <option value="3">3 Stars</option>
                        <option value="2">2 Stars</option>
                        <option value="1">1 Star</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Comment</label>
                    <textarea name="comment" class="form-control" rows="3" required></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Submit Review</button>
            </form>
        </div>
        <% } %>
    </div>
</div>

<script>
async function addToCart(productId, btn) {
    const qtyInput = document.getElementById('pd-qty');
    const quantity = qtyInput ? qtyInput.value : 1;
    const originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Adding...';
    try {
        const response = await fetch('/cart/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `productId=${productId}&quantity=${quantity}`
        });
        if (response.ok || response.redirected) {
            btn.textContent = '✓ Added!';
            btn.style.background = 'var(--sage)';
            showToast('Product added to cart!', 'success');
            setTimeout(() => { btn.textContent = originalText; btn.style.background = ''; btn.disabled = false; }, 2000);
        } else {
            btn.textContent = originalText;
            btn.disabled = false;
            showToast('Failed to add to cart. Please login first.', 'error');
        }
    } catch(e) {
        btn.textContent = originalText;
        btn.disabled = false;
        showToast('Network error. Please try again.', 'error');
    }
}
function showToast(message, type) {
    let toast = document.getElementById('cart-toast');
    if (!toast) {
        toast = document.createElement('div');
        toast.id = 'cart-toast';
        toast.style.cssText = 'position:fixed;bottom:2rem;right:2rem;z-index:9999;padding:0.85rem 1.5rem;border-radius:var(--radius-md);font-family:"DM Sans",sans-serif;font-size:0.88rem;font-weight:500;color:#fff;box-shadow:0 8px 32px rgba(0,0,0,0.15);transition:all 0.3s ease;opacity:0;transform:translateY(20px);pointer-events:none;';
        document.body.appendChild(toast);
    }
    toast.textContent = message;
    toast.style.background = type === 'success' ? '#7A9E7E' : '#C47070';
    toast.style.opacity = '1';
    toast.style.transform = 'translateY(0)';
    toast.style.pointerEvents = 'auto';
    setTimeout(() => { toast.style.opacity = '0'; toast.style.transform = 'translateY(20px)'; }, 3000);
}
</script>

<%- include('../partials/footer') %>
