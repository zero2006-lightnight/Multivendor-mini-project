<%- include('../partials/header') %>

<div class="cart-page">
    <div class="page-header" style="display:flex;align-items:center;gap:1rem;">
        <a href="/" class="btn btn-outline-secondary" style="padding:0.5rem 0.8rem;font-size:1.1rem;" title="Continue Shopping">&larr;</a>
        <h2 style="margin-bottom:0;">Shopping Cart</h2>
    </div>

    <% if (cart && cart.products.length > 0) { %>
        <div class="row">
            <div class="col-lg-8">
                <div class="card" style="border-radius: var(--radius-md);">
                    <div class="card-body" style="padding: 0.5rem 1.5rem;">
                        <% cart.products.forEach(item => { %>
                            <div class="cart-item">
                                <div class="cart-item-info">
                                    <div class="cart-item-name"><%= item.product.name %></div>
                                    <div class="cart-item-meta">Qty: <%= item.quantity %></div>
                                </div>
                                <div class="cart-item-qty">
                                    <%= item.quantity %> x &#8377;<%= item.product.price.toFixed(2) %>
                                </div>
                                <div class="cart-item-price">
                                    &#8377;<%= (item.product.price * item.quantity).toFixed(2) %>
                                </div>
                                <form action="/cart/remove" method="POST" style="display:inline;">
                                    <input type="hidden" name="productId" value="<%= item.product._id %>">
                                    <button type="submit" class="cart-item-remove" title="Remove">&#10005;</button>
                                </form>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="cart-summary">
                    <div class="cart-summary-row">
                        <span style="color: var(--text-secondary);">Subtotal</span>
                        <span class="price-tag">&#8377;<%= cart.totalAmount.toFixed(2) %></span>
                    </div>

                    <% if (discount > 0) { %>
                        <div class="cart-summary-row" style="color: var(--sage);">
                            <span>Coupon (<%= discount %>% OFF)</span>
                            <span style="font-family: 'JetBrains Mono', monospace; font-weight: 600;">
                                - &#8377;<%= (cart.totalAmount * discount / 100).toFixed(2) %>
                            </span>
                        </div>
                    <% } %>

                    <div class="cart-summary-row total">
                        <span>Total</span>
                        <span class="price-tag">
                            &#8377;<%= (discount > 0 ? finalTotal : cart.totalAmount).toFixed(2) %>
                        </span>
                    </div>

                    <div class="cart-coupon">
                        <form action="/apply-coupon" method="POST">
                            <label class="form-label" style="margin-bottom: 0.5rem;">Have a coupon?</label>
                            <div class="input-group">
                                <input type="text" name="code" class="form-control"
                                       placeholder="Enter code" required
                                       style="border-radius: var(--radius-sm) 0 0 var(--radius-sm) !important;">
                                <button type="submit" class="btn btn-primary"
                                        style="border-radius: 0 var(--radius-sm) var(--radius-sm) 0 !important;">
                                    Apply
                                </button>
                            </div>
                        </form>

                        <% if (coupons && coupons.length > 0) { %>
                            <div style="margin-top: 1rem;">
                                <div style="font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.5rem;">Available Coupons</div>
                                <ul class="coupon-list">
                                    <% coupons.forEach(coupon => { %>
                                        <li><%= coupon.code %> &mdash; <%= coupon.discount %>% OFF</li>
                                    <% }) %>
                                </ul>
                            </div>
                        <% } %>
                    </div>

                    <a href="/checkout" class="btn btn-primary" style="width: 100%; margin-top: 1.5rem; padding: 0.8rem;">
                        Proceed to Checkout
                    </a>
                </div>
            </div>
        </div>
    <% } else { %>
        <div class="empty-state">
            <div class="empty-state-icon">&#128722;</div>
            <h3>Your cart is empty</h3>
            <p>Looks like you haven't added anything yet.</p>
            <a href="/" class="btn btn-primary">Continue Shopping</a>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>
