<%- include('../partials/header') %>

<div class="checkout-page">
    <div class="page-header" style="display:flex;align-items:center;gap:1rem;">
        <a href="/cart" class="btn btn-outline-secondary" style="padding:0.5rem 0.8rem;font-size:1.1rem;" title="Back to Cart">&larr;</a>
        <h2 style="margin-bottom:0;">Checkout</h2>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="checkout-summary">
                <h3 style="font-family: 'DM Sans', sans-serif; font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 1.25rem;">Order Summary</h3>

                <% cart.products.forEach(item => { %>
                    <div class="checkout-item">
                        <div>
                            <div class="checkout-item-name"><%= item.product.name %></div>
                            <div class="checkout-item-qty">Qty: <%= item.quantity %></div>
                        </div>
                        <div class="checkout-item-price">&#8377;<%= (item.product.price * item.quantity).toFixed(2) %></div>
                    </div>
                <% }) %>

                <div class="cart-summary-row" style="padding-top: 1rem;">
                    <span style="color: var(--text-secondary);">Subtotal</span>
                    <span class="price-tag">&#8377;<%= cart.totalAmount.toFixed(2) %></span>
                </div>

                <% if (discount > 0) { %>
                    <div class="cart-summary-row" style="color: var(--sage);">
                        <span>Coupon (<%= discount %>% OFF)</span>
                        <span style="font-family: 'JetBrains Mono', monospace; font-weight: 600;">
                            - &#8377;<%= (cart.totalAmount * discount / 100).toFixed(2) %>
                        </span>
                    </div>
                <% } %>

                <div class="checkout-total">
                    <span>Total</span>
                    <span class="price-tag">
                        &#8377;<%= (discount > 0 ? finalTotal : cart.totalAmount).toFixed(2) %>
                    </span>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="checkout-form">
                <h3 style="font-family: 'DM Sans', sans-serif; font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 1.25rem;">Shipping Address</h3>

                <form action="/order" method="POST">
                    <div class="mb-3">
                        <label for="street" class="form-label">Street</label>
                        <input type="text" class="form-control" id="street" name="street" required>
                    </div>
                    <div class="mb-3">
                        <label for="city" class="form-label">City</label>
                        <input type="text" class="form-control" id="city" name="city" required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="state" class="form-label">State</label>
                            <input type="text" class="form-control" id="state" name="state" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="zipCode" class="form-label">Zip Code</label>
                            <input type="text" class="form-control" id="zipCode" name="zipCode" required>
                        </div>
                    </div>
                    <input type="hidden" name="razorpay_payment_id" id="razorpay_payment_id">
                    <input type="hidden" name="razorpay_order_id" id="razorpay_order_id">
                    <input type="hidden" name="razorpay_signature" id="razorpay_signature">
                    <button type="button" id="rzp-button" class="btn btn-primary" style="width: 100%; padding: 0.85rem; margin-top: 0.5rem;">
                        Pay with Razorpay
                    </button>
                    <div id="payment-error" style="display:none;background:var(--rose-dim);border:1px solid rgba(196,112,112,0.2);color:var(--rose);border-radius:var(--radius-md);padding:1rem;margin-top:1rem;font-size:0.88rem;">
                        <div id="payment-error-text"></div>
                        <button type="button" id="retry-payment" class="btn btn-outline-secondary" style="margin-top:0.75rem;padding:0.4rem 1rem;font-size:0.82rem;border-radius:var(--radius-sm);">Retry Payment</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
const errorDiv = document.getElementById('payment-error');
const errorText = document.getElementById('payment-error-text');
const retryBtn = document.getElementById('retry-payment');

function showError(msg) {
    errorText.textContent = msg;
    errorDiv.style.display = 'block';
}

function hideError() {
    errorDiv.style.display = 'none';
}

function resetButton() {
    const btn = document.getElementById('rzp-button');
    btn.disabled = false;
    btn.textContent = 'Pay with Razorpay';
    btn.style.background = '';
}

async function openRazorpay() {
    hideError();
    const btn = document.getElementById('rzp-button');
    btn.disabled = true;
    btn.textContent = 'Processing...';

    try {
        const response = await fetch('/create-razorpay-order', { method: 'POST' });
        const data = await response.json();

        if (!response.ok || !data.id) {
            showError(data.message || 'Failed to create payment order. Please check your Razorpay configuration.');
            resetButton();
            return;
        }

        const options = {
            key: "<%= razorpayKey %>",
            amount: data.amount,
            currency: data.currency,
            name: "Marketplace",
            description: "Order Payment",
            order_id: data.id,
            handler: function(response) {
                document.getElementById('razorpay_payment_id').value = response.razorpay_payment_id;
                document.getElementById('razorpay_order_id').value = response.razorpay_order_id;
                document.getElementById('razorpay_signature').value = response.razorpay_signature;
                btn.textContent = 'Payment Successful!';
                btn.style.background = 'var(--sage)';
                document.querySelector('form').submit();
            },
            modal: {
                ondismiss: function() {
                    showError('Payment was cancelled. You can try again with Netbanking, UPI, or Wallet.');
                    resetButton();
                }
            },
            prefill: {},
            theme: { color: '#B8956A' }
        };

        const rzp = new Razorpay(options);

        rzp.on('payment.failed', function(response) {
            const desc = response.error.description || 'Unknown error';
            let msg = 'Payment failed: ' + desc;
            if (desc.toLowerCase().includes('international')) {
                msg = 'International cards are not supported. Please pay using Netbanking, UPI, or Wallet instead.';
            }
            showError(msg);
            resetButton();
        });

        rzp.open();
    } catch (err) {
        showError('Could not connect to payment gateway. Please try again later.');
        resetButton();
    }
}

document.getElementById('rzp-button').onclick = openRazorpay;
retryBtn.onclick = openRazorpay;
</script>

<%- include('../partials/footer') %>
