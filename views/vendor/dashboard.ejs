<%- include('../partials/header') %>

<div class="vendor-page">
    <div class="page-header">
        <h2>Vendor Dashboard</h2>
    </div>

    <div style="display: flex; gap: 0.75rem; margin-bottom: 2rem;">
        <a href="/vendor/products/add" class="btn btn-primary">Add Product</a>
        <a href="/vendor/orders" class="btn btn-outline-secondary">View Orders</a>
    </div>

    <div class="row">
        <% if (products.length > 0) { %>
            <% products.forEach(product => { %>
            <div class="col-md-4 mb-4">
                <div class="vendor-product-card">
                    <% const img = product.image || '/images/placeholder.png'; %>
                    <img src="<%= img %>" class="card-img-top" alt="<%= product.name %>">
                    <div class="card-body">
                        <div class="card-title"><%= product.name %></div>
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                            <span class="badge bg-secondary"><%= product.category %></span>
                            <% if (product.stock > 0) { %>
                                <span class="stock-indicator in-stock"><%= product.stock %> in stock</span>
                            <% } else { %>
                                <span class="stock-indicator out-of-stock">Out of stock</span>
                            <% } %>
                        </div>
                        <div class="price-tag">&#8377;<%= product.price.toFixed(2) %></div>
                    </div>
                    <div class="vendor-product-actions">
                        <a href="/vendor/products/edit/<%= product._id %>" class="btn btn-primary btn-sm">Edit</a>
                        <form action="/vendor/products/delete/<%= product._id %>" method="POST" style="display:inline; flex: 1;" onsubmit="return confirm('Are you sure you want to delete this product?')">
                            <button type="submit" class="btn btn-outline-danger btn-sm" style="width: 100%;">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
            <% }) %>
        <% } else { %>
            <div class="col-12">
                <div class="empty-state">
                    <div class="empty-state-icon">&#128230;</div>
                    <h3>No products yet</h3>
                    <p>Click "Add Product" to get started.</p>
                    <a href="/vendor/products/add" class="btn btn-primary">Add Product</a>
                </div>
            </div>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>
