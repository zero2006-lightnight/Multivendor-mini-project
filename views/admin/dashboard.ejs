<%- include('../partials/header') %>

<h2>Admin Dashboard</h2>

<!-- Quick Stats -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary">
            <div class="card-body text-center">
                <h6 class="card-title">Total Users</h6>
                <h3><%= typeof totalUsers !== 'undefined' ? totalUsers : '-' %></h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body text-center">
                <h6 class="card-title">Total Products</h6>
                <h3><%= typeof totalProducts !== 'undefined' ? totalProducts : '-' %></h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info">
            <div class="card-body text-center">
                <h6 class="card-title">Total Orders</h6>
                <h3><%= typeof totalOrders !== 'undefined' ? totalOrders : '-' %></h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning">
            <div class="card-body text-center">
                <h6 class="card-title">Revenue</h6>
                <h3>₹<%= typeof totalRevenue !== 'undefined' ? totalRevenue.toFixed(0) : '-' %></h3>
            </div>
        </div>
    </div>
</div>

<!-- Quick Links -->
<div class="row">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-body text-center">
                <h5>👥 Users</h5>
                <a href="/admin/users" class="btn btn-outline-primary">Manage Users</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-body text-center">
                <h5>📦 Products</h5>
                <a href="/admin/products" class="btn btn-outline-success">Manage Products</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-body text-center">
                <h5>📋 Orders</h5>
                <a href="/admin/orders" class="btn btn-outline-info">Manage Orders</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-body text-center">
                <h5>📊 Analytics</h5>
                <a href="/admin/analytics" class="btn btn-outline-warning">View Analytics</a>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
