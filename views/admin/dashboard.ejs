<%- include('../partials/header') %>

<div class="admin-page">
    <div class="page-header">
        <h2>Admin Dashboard</h2>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon">&#128101;</div>
                <div class="stat-label">Total Users</div>
                <div class="stat-value"><%= typeof totalUsers !== 'undefined' ? totalUsers : '-' %></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon">&#128230;</div>
                <div class="stat-label">Total Products</div>
                <div class="stat-value"><%= typeof totalProducts !== 'undefined' ? totalProducts : '-' %></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon">&#128196;</div>
                <div class="stat-label">Total Orders</div>
                <div class="stat-value"><%= typeof totalOrders !== 'undefined' ? totalOrders : '-' %></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon">&#128176;</div>
                <div class="stat-label">Revenue</div>
                <div class="stat-value">&#8377;<%= typeof totalRevenue !== 'undefined' ? totalRevenue.toFixed(0) : '-' %></div>
            </div>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="form-section-title" style="margin-bottom: 1rem;">Quick Links</div>
    <div class="quick-links">
        <a href="/admin/users" class="quick-link-card" style="text-decoration: none; color: inherit;">
            <div class="link-icon">&#128101;</div>
            <h5>Users</h5>
            <span class="btn btn-outline-primary btn-sm">Manage</span>
        </a>
        <a href="/admin/products" class="quick-link-card" style="text-decoration: none; color: inherit;">
            <div class="link-icon">&#128230;</div>
            <h5>Products</h5>
            <span class="btn btn-outline-primary btn-sm">Manage</span>
        </a>
        <a href="/admin/orders" class="quick-link-card" style="text-decoration: none; color: inherit;">
            <div class="link-icon">&#128196;</div>
            <h5>Orders</h5>
            <span class="btn btn-outline-primary btn-sm">Manage</span>
        </a>
        <a href="/admin/analytics" class="quick-link-card" style="text-decoration: none; color: inherit;">
            <div class="link-icon">&#128200;</div>
            <h5>Analytics</h5>
            <span class="btn btn-outline-primary btn-sm">View</span>
        </a>
    </div>
</div>

<%- include('../partials/footer') %>
