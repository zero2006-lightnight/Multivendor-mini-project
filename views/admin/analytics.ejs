<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📊 Analytics Dashboard</h2>
    <a href="/admin/dashboard" class="btn btn-outline-secondary">← Back to Dashboard</a>
</div>

<!-- Stats Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body text-center">
                <h6 class="card-title">Total Revenue</h6>
                <h3>₹<%= totalRevenue.toFixed(2) %></h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-primary">
            <div class="card-body text-center">
                <h6 class="card-title">Total Orders</h6>
                <h3><%= totalOrders %></h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info">
            <div class="card-body text-center">
                <h6 class="card-title">Avg Order Value</h6>
                <h3>₹<%= avgOrderValue.toFixed(2) %></h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning">
            <div class="card-body text-center">
                <h6 class="card-title">Total Products</h6>
                <h3><%= totalProducts %></h3>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Orders by Status -->
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-header"><strong>Orders by Status</strong></div>
            <div class="card-body">
                <% if (statusCounts.length > 0) { %>
                    <% statusCounts.forEach(sc => { %>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>
                                <span class="badge 
                                    <% if (sc._id === 'Delivered') { %>bg-success
                                    <% } else if (sc._id === 'Cancelled') { %>bg-danger
                                    <% } else if (sc._id === 'Shipped') { %>bg-info
                                    <% } else if (sc._id === 'Processing') { %>bg-primary
                                    <% } else if (sc._id === 'Paid') { %>bg-warning text-dark
                                    <% } else { %>bg-secondary<% } %>">
                                    <%= sc._id %>
                                </span>
                            </span>
                            <strong><%= sc.count %></strong>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-muted">No orders yet</p>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Users by Role -->
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-header"><strong>Users by Role</strong></div>
            <div class="card-body">
                <% if (usersByRole.length > 0) { %>
                    <% usersByRole.forEach(ur => { %>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>
                                <span class="badge 
                                    <% if (ur._id === 'admin') { %>bg-danger
                                    <% } else if (ur._id === 'vendor') { %>bg-primary
                                    <% } else { %>bg-secondary<% } %>">
                                    <%= ur._id %>
                                </span>
                            </span>
                            <strong><%= ur.count %></strong>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-muted">No users yet</p>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Monthly Revenue -->
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-header"><strong>Monthly Revenue</strong></div>
            <div class="card-body" style="max-height: 300px; overflow-y: auto;">
                <% if (monthlyRevenue.length > 0) { %>
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Month</th>
                                <th>Revenue</th>
                                <th>Orders</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% monthlyRevenue.forEach(mr => { %>
                                <tr>
                                    <td><%= mr._id.year %>-<%= String(mr._id.month).padStart(2, '0') %></td>
                                    <td>₹<%= mr.revenue.toFixed(2) %></td>
                                    <td><%= mr.orders %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } else { %>
                    <p class="text-muted">No revenue data yet</p>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Top Products -->
<div class="card mb-4">
    <div class="card-header"><strong>🏆 Top Selling Products</strong></div>
    <div class="card-body">
        <% if (topProducts.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Product</th>
                            <th>Total Sold</th>
                            <th>Total Revenue</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% topProducts.forEach((tp, idx) => { %>
                            <tr>
                                <td><%= idx + 1 %></td>
                                <td><%= tp.product ? tp.product.name : 'Deleted Product' %></td>
                                <td><%= tp.totalQuantity %></td>
                                <td>₹<%= tp.totalRevenue.toFixed(2) %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <p class="text-muted text-center py-3">No product sales data yet</p>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>
